{
  "$schema": "https://aka.ms/dsc/schemas/v3/bundled/resource/manifest.json",
  "type": "Microsoft.Python/Discover",
  "version": "0.1.0",
  "description": "Discovers DSC resources packaged in Python distributions.",
  "condition": "[not(and(equals(tryWhich('python'), null()), equals(tryWhich('python3'), null())))]",
  "discover": {
    "executable": "python",
    "args": [
      "./python.discover.py"
    ]
  }
}
