{
  "$schema": "https://aka.ms/dsc/schemas/v3/bundled/adaptedresource/manifest.json",
  "type": "Example/FilePresence",
  "kind": "resource",
  "version": "1.0.0",
  "capabilities": [
    "get",
    "set",
    "test",
    "delete",
    "export"
  ],
  "requireAdapter": "Microsoft.Adapter/Python",
  "content": {
    "module": "file_presence.resource",
    "class": "FilePresenceResource"
  },
  "description": "Ensures a file exists or does not exist at the given path.",
  "schema": {
    "embedded": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "description": "Absolute path of the file to manage.",
          "title": "Path"
        },
        "_exist": {
          "type": "boolean",
          "description": "Whether the file should exist.",
          "title": "Exist"
        }
      },
      "additionalProperties": false,
      "required": [
        "path"
      ]
    }
  }
}