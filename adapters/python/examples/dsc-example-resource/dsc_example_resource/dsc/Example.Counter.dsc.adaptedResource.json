{
  "$schema": "https://aka.ms/dsc/schemas/v3/bundled/adaptedresource/manifest.json",
  "type": "Example/Counter",
  "kind": "resource",
  "version": "1.0.0",
  "capabilities": [
    "get",
    "set",
    "test",
    "delete",
    "export"
  ],
  "requireAdapter": "Microsoft.Adapter/Python",
  "content": {
    "module": "dsc_example_resource.resources",
    "class": "CounterResource"
  },
  "description": "Manages a named integer counter persisted in ~/.dsc/example_counters.json.",
  "schema": {
    "embedded": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the counter.",
          "title": "ID"
        },
        "value": {
          "type": "integer",
          "description": "Current counter value.",
          "title": "Value"
        }
      },
      "additionalProperties": false,
      "required": [
        "id"
      ]
    }
  }
}